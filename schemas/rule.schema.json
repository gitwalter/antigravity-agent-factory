{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://antigravity-agent-factory.dev/schemas/rule.schema.json",
    "title": "Governance Rule Schema",
    "description": "Schema for governance rule markdown files in .agent/rules/*.md",
    "type": "object",
    "required": [
        "title",
        "trigger",
        "context",
        "requirements"
    ],
    "properties": {
        "title": {
            "type": "string",
            "minLength": 5,
            "description": "The display title of the rule"
        },
        "trigger": {
            "type": "string",
            "enum": [
                "model_decision",
                "user_request",
                "system_event",
                "manual",
                "always"
            ],
            "description": "Context or event that triggers this rule"
        },
        "context": {
            "type": "string",
            "minLength": 10,
            "description": "Background and rationale for this rule"
        },
        "requirements": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "minItems": 1,
            "description": "Mandatory constraints and directives"
        },
        "process": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Step-by-step protocol to follow"
        },
        "best_practices": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Recommended approaches"
        },
        "anti_patterns": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "Behaviors to avoid"
        },
        "axioms": {
            "type": "array",
            "items": {
                "type": "string",
                "pattern": "^A[0-6]$|^Axiom Zero$"
            },
            "description": "Core axioms linked to this rule (A1-A6)"
        }
    }
}
