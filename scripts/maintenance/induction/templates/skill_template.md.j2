---
name: {{ name }}
description: {{ description }}
type: skill
version: {{ version | default('1.0.0') }}
category: {{ category }}
agents: {{ agents | default(['python-ai-specialist']) | tojson }}
knowledge: {{ knowledge | default(['best-practices.json']) | tojson }}
tools: {{ tools | default(['none']) | tojson }}
related_skills: {{ related_skills | default(['none']) | tojson }}
templates: {{ templates | default(['none']) | tojson }}
references: {{ references | default(['none']) | tojson }}
settings:
  auto_approve: {{ settings.auto_approve | default(false) | tojson }}
  retry_limit: {{ settings.retry_limit | default(3) }}
  timeout_seconds: {{ settings.timeout_seconds | default(300) }}
  safe_to_parallelize: {{ settings.safe_to_parallelize | default(false) }}
  orchestration_pattern: {{ settings.orchestration_pattern | default('chain') }}
---

# {{ name | replace('-', ' ') | title }}

## Mission
{{ mission }}

## When to Use
{% for case in when_to_use %}
- {{ case }}
{% endfor %}

## Prerequisites
- Access to the Antigravity Factory infrastructure.
{% for prereq in prerequisites %}
- {{ prereq }}
{% endfor %}

## Process
{% for phase in process %}
### Phase {{ loop.index }}: {{ phase.name }}
{% for step in phase.steps %}
{{ loop.index }}. {{ step }}
{% endfor %}

{% endfor %}

## Best Practices
{% for bp in best_practices %}
- {{ bp }}
{% endfor %}
