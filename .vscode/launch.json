{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: Statistical Dashboard",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/projects/statistical_dashboards/app.py"
            ],
            "jinja": true,
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit: RAG Knowledge Explorer",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/projects/rag_knowledge_explorer/app.py"
            ],
            "jinja": true,
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "IDX Backend (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "mcp_api:app",
                "--host", "0.0.0.0",
                "--port", "8000",
                "--reload"
            ],
            "cwd": "${workspaceFolder}/scripts/api",
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "LANGSMITH_TRACING": "true",
                "LANGSMITH_PROJECT": "antigravity-idx"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "IDX Frontend (Next.js)",
            "type": "node-terminal",
            "request": "launch",
            "command": "npm run dev",
            "cwd": "${workspaceFolder}/ui",
            "env": {
                "NEXT_PUBLIC_API_URL": "http://localhost:8000"
            }
        }
    ],
    "compounds": [
        {
            "name": "IDX Full Stack",
            "configurations": ["IDX Backend (FastAPI)", "IDX Frontend (Next.js)"],
            "stopAll": true
        }
    ]
}
