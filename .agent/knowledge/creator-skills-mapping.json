                "output_artifact": "Knowledge Files",
                "schema_enforced": "knowledge-file.schema.json",
                "active_consumers": [
                    "knowledge-operations-specialist (agent)"
                ]
            },
            {
                "skill": "pattern-creator",
                "output_artifact": "Patterns",
                "schema_enforced": "agent-pattern.json",
                "active_consumers": []
            },
            {
                "skill": "skill-creator",
                "output_artifact": "Skills",
