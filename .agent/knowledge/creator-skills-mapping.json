{
    "id": "creator-skills-mapping",
    "name": "Creator Skills Mapping",
    "title": "Creator Skills Mapping",
    "description": "Defines the exact output artifacts for the factory's specialized creator skills, along with their active consumers.",
    "version": "1.0.0",
    "category": "factory-architecture",
    "patterns": {
        "artifact_generation": {
            "description": "Generating a factory artifact using a creator skill.",
            "code_example": "agent.execute_skill('knowledge-creator', prompt='...')"
        }
    },
    "best_practices": [
        "Always validate the generated artifacts against their JSON schemas.",
        "Ensure specific consumers are updated when creator skills produce new output types."
    ],
    "anti_patterns": [
        "Generating factory artifacts manually without using the dedicated creator skills.",
        "Ignoring schema validation errors during creation."
    ],
    "content": {
