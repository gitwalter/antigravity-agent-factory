<div style="font-family:'Inter',system-ui,sans-serif;line-height:1.4;color:#1a1a1a;max-width:900px;">{%- if summary -%}<section style="margin-bottom:6px;"><h3 style="display:flex;align-items:center;gap:6px;border-bottom:1px solid #e5e7eb;padding-bottom:1px;margin:0 0 2px 0;color:#111827;font-size:1em;"><span>🏁</span> Solution Summary</h3><div style="color:#374151;">{{ summary | trim }}</div></section>{%- endif -%}{%- if changes -%}<section style="margin-bottom:6px;"><h4 style="margin:0 0 2px 0;color:#111827;font-size:0.9em;">🛠️ Changes</h4><ul style="margin:0;padding-left:18px;color:#374151;font-size:0.9em;">{%- for c in changes -%}<li style="margin-bottom:1px;">{{ c | trim }}</li>{%- endfor -%}</ul></section>{%- endif -%}{%- if verification_evidence -%}<section style="margin-bottom:6px;padding:6px;background-color:#f0fdf4;border-radius:4px;border:1px solid #dcfce7;"><h4 style="margin:0 0 2px 0;color:#166534;font-size:0.9em;">✅ Verification Evidence</h4><ul style="margin:0;padding-left:18px;color:#14532d;font-size:0.85em;">{%- for e in verification_evidence -%}<li style="margin-bottom:1px;">{{ e | trim }}</li>{%- endfor -%}</ul></section>{%- endif -%}{%- if evolution -%}<section style="margin-bottom:6px;"><h4 style="margin:0 0 2px 0;color:#111827;font-size:0.9em;">📈 Evolution</h4><ul style="margin:0;padding-left:18px;color:#374151;font-size:0.85em;">{%- for ev in evolution -%}<li style="margin-bottom:1px;">{{ ev | trim }}</li>{%- endfor -%}</ul></section>{%- endif -%}{%- if architectural_decisions -%}<section style="margin-bottom:6px;padding:6px;background-color:#fef2f2;border-radius:4px;border:1px solid #fee2e2;"><h4 style="margin:0 0 2px 0;color:#991b1b;font-size:0.9em;">🧠 Architectural Decisions</h4><ul style="margin:0;padding-left:18px;color:#7f1d1d;font-size:0.85em;">{%- for d in architectural_decisions -%}<li style="margin-bottom:1px;">{{ d | trim }}</li>{%- endfor -%}</ul></section>{%- endif -%}{%- if lessons_learned -%}<section style="margin-bottom:6px;padding:6px;background-color:#fffbeb;border-radius:4px;border:1px solid #fef3c7;"><h4 style="margin:0 0 2px 0;color:#92400e;font-size:0.9em;">💡 Lessons Learned</h4><ul style="margin:0;padding-left:18px;color:#78350f;font-size:0.85em;">{%- for l in lessons_learned -%}<li style="margin-bottom:1px;">{{ l | trim }}</li>{%- endfor -%}</ul></section>{%- endif -%}</div>
