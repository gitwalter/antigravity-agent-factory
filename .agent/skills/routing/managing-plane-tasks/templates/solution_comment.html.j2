{%- set valid_files = [] -%}{%- for f in files_affected if f|trim -%}{%- do valid_files.append(f|trim) -%}{%- endfor -%}
{%- set valid_verif = [] -%}{%- for v in verification if v.get('type')|trim and v.get('result')|trim -%}{%- do valid_verif.append(v) -%}{%- endfor -%}
{%- set valid_evol = [] -%}{%- for e in evolution if e|trim -%}{%- do valid_evol.append(e|trim) -%}{%- endfor -%}
{%- set valid_arch = [] -%}{%- for a in architectural_decisions if a|trim -%}{%- do valid_arch.append(a|trim) -%}{%- endfor -%}
<h3>🚀 Solution Summary</h3>
<p>{{ summary|trim }}</p>
{%- if valid_arch -%}
<hr>
<h3>🧠 Architectural Decisions</h3>
<ul>
  {%- for a in valid_arch -%}
  <li>{{ a }}</li>
  {%- endfor -%}
</ul>
{%- endif -%}
{%- if valid_files -%}
<hr>
<h3>📂 Files Affected</h3>
<ul>
  {%- for file in valid_files -%}
  <li><code>{{ file }}</code></li>
  {%- endfor -%}
</ul>
{%- endif -%}
{%- if valid_verif -%}
<hr>
<h3>✅ Verification Proof</h3>
<ul>
  {%- for v in valid_verif -%}
  <li><strong>[{{ v.type|trim | upper }}]</strong> {{ v.result|trim | upper }}</li>
  {%- endfor -%}
</ul>
{%- endif -%}
{%- if valid_evol -%}
<hr>
<h3>🏗️ Factory Evolution</h3>
<ul>
  {%- for item in valid_evol -%}
  <li>{{ item }}</li>
  {%- endfor -%}
</ul>
{%- endif -%}
{%- if notes and notes|trim -%}
<hr>
<blockquote><strong>Notes:</strong><br>{{ notes|trim }}</blockquote>
{%- endif -%}
